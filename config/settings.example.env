# ============================================================
# Neo Kotak Credentials
# SDK: Kotak-neo-api-v2
# Install: pip install git+https://github.com/Kotak-Neo/Kotak-neo-api-v2.git
# ============================================================

# Mobile number (10 digits, no +91 needed)
NEO_MOBILE=9880158227

# UCC — Unique Client Code (shown on login screen / Kotak profile)
NEO_UCC=X3DNA

# Consumer Key — from Kotak Neo app → Invest → Trade API → API Dashboard
NEO_CONSUMER_KEY=eeeeee-333-eee-sds-cccccc

# MPIN — your 6-digit Kotak trading PIN
NEO_MPIN=123456

# Environment: prod = live trading, uat = sandbox/testing
NEO_ENVIRONMENT=prod

# NOTE: No consumer_secret needed — this SDK only requires consumer_key
# NOTE: TOTP is never stored — enter it fresh each session in the login UI

# ============================================================
# Trading Parameters
# ============================================================
TRADING_MODE=paper
# Instrument: NIFTY (NSE, strike step 50, lot 65, expiry Tuesday)
#             SENSEX (BSE, strike step 100, lot 10, expiry Friday)
INSTRUMENT=NIFTY
LOT_SIZE=65
STARTING_LOTS=2
TOTAL_CAPITAL=200000
MAX_RISK_PER_TRADE=2000
DAILY_TARGET=5000
MAX_DAILY_LOSS=6000

# ============================================================
# Timing (IST)
# ============================================================
MARKET_OPEN=09:15
TRADING_START=09:20
TRADING_STOP=15:00
SQUARE_OFF_TIME=15:20

# ============================================================
# Signal Thresholds
# ============================================================
MIN_SIGNAL_SCORE=6
MIN_RR_RATIO=1.2
MIN_CONFIDENCE=60
ATR_PERIOD=14
ATR_SL_MULTIPLIER=0.5
PREMIUM_SL_PCT=0.10
MIN_SL_ABSOLUTE=2.0
TRAIL_ACTIVATION_R=0.5
TRAIL_ATR_MULTIPLIER=1.5

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log
DB_PATH=logs/trades.db
